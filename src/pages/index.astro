---
import '../styles/global.css';
import { legalDocuments } from '../lib/legal-documents';

const title = 'KDIX.Garage Legal';
const description = 'KDIX.Garage の規約文書一覧';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto min-h-screen max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
      <header class="mb-8 border-b border-neutral-200 pb-6">
        <p class="mb-3 text-sm font-medium tracking-wide text-neutral-500">KDIX.Garage Legal</p>
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-950 sm:text-4xl">{title}</h1>
        <p class="mt-4 text-sm leading-6 text-neutral-600">{description}</p>
      </header>

      <section aria-label="規約文書一覧" class="grid overflow-hidden rounded-md bg-white">
        {
          legalDocuments.map((document) => (
            <a
              class="flex h-14 items-center gap-3 border-b px-2 border-neutral-200/0 hover:border-neutral-200"
              href={document.path}
            >
              <span class="flex size-9 shrink-0 items-center justify-center rounded-md bg-neutral-100 text-xl" aria-hidden="true">
                {document.emoji}
              </span>
              <h2 class="min-w-0 flex-1 truncate font-semibold tracking-tight text-neutral-950">
                {document.title}
              </h2>
              <time class="shrink-0 text-xs text-neutral-500 font-mono" datetime={document.updatedAt}>
                {document.updatedAt}
              </time>
            </a>
          ))
        }
      </section>
    </main>
  </body>
</html>
