{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kdix-garage-legal",
  "compatibility_date": "2026-06-10",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "legal.kdix.dev",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "preview_urls": false
}
